{
  "name": "nexpress-hosted-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "predev": "tsx scripts/dev-notice.ts",
    "dev": "next dev",
    "build": "tsx scripts/build.ts",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "deploy:plan": "tsx scripts/deploy-plan.ts",
    "doctor": "tsx scripts/doctor.ts",
    "doctor:prod": "tsx scripts/doctor.ts --prod",
    "demo:reset": "tsx scripts/demo-reset.ts",
    "gettext": "tsx scripts/gettext.ts",
    "ops:backup": "tsx scripts/ops-backup.ts",
    "ops:contracts": "tsx scripts/ops-contracts.ts",
    "ops:health": "tsx scripts/ops-health.ts",
    "ops:jobs": "tsx scripts/ops-jobs.ts",
    "ops:migrate": "tsx scripts/ops-migrate.ts",
    "ops:plugins": "tsx scripts/ops-plugins.ts",
    "ops:preflight": "tsx scripts/ops-preflight.ts",
    "ops:release": "tsx scripts/release.ts",
    "ops:runbook": "tsx scripts/runbook.ts",
    "ops:status": "tsx scripts/ops-status.ts",
    "ops:storage": "tsx scripts/ops-storage.ts",
    "postinstall": "tsx scripts/postinstall-notice.ts",
    "release": "tsx scripts/release.ts",
    "runbook": "tsx scripts/runbook.ts",
    "schema:gen": "tsx scripts/generate-schema.ts",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "seed:content": "tsx scripts/seed-content.ts",
    "setup": "tsx scripts/setup-server.ts",
    "worker": "tsx scripts/worker.ts",
    "xliff": "tsx scripts/xliff.ts",
    "db:check": "pnpm db:generate && git diff --exit-code -- drizzle && test -z \"$(git status --porcelain --untracked-files=all -- drizzle)\"",
    "db:generate": "pnpm schema:gen && drizzle-kit generate",
    "db:migrate": "tsx scripts/run-migrations.ts",
    "db:push": "pnpm schema:gen && drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@nexpress/admin": "0.4.1",
    "@nexpress/app": "0.4.1",
    "@nexpress/auth-pages": "0.4.1",
    "@nexpress/blocks": "0.4.1",
    "@nexpress/core": "0.4.1",
    "@nexpress/editor": "0.4.1",
    "@nexpress/gettext": "0.4.1",
    "@nexpress/next": "0.4.1",
    "@nexpress/plugin-sdk": "0.4.1",
    "@nexpress/theme": "0.4.1",
    "@nexpress/theme-default": "0.4.1",
    "@nexpress/theme-docs": "0.4.1",
    "@nexpress/theme-magazine": "0.4.1",
    "@nexpress/theme-portfolio": "0.4.1",
    "@nexpress/xliff": "0.4.1",
    "@vercel/analytics": "^2.0.1",
    "drizzle-orm": "^0.45.2",
    "next": "^16.0.0",
    "nodemailer": "^9.0.0",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "0.35.3"
  },
  "devDependencies": {
    "@nexpress/cli": "0.4.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.2.4",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.0"
  }
}
